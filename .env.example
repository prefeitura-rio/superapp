# Server-only API base URLs
BASE_API_URL_RMI=http://localhost:3001
COURSES_BASE_API_URL=http://localhost:3002
BASE_API_URL_APP_BUSCA_SEARCH=http://localhost:3003
BASE_API_URL_SUBPAV_OSA_API=http://localhost:3004
BASE_API_URL_APP_CATALOGO=http://localhost:3005

# Rio Queue — controle de acesso por fila virtual
# URL do bucket onde rio-queue.min.js está hospedado (ex: GCS).
NEXT_PUBLIC_RIO_QUEUE_URL=https://storage.googleapis.com/rio-queue
# URL da API backend do rio-queue. Deve ser diferente do bucket acima.
# Enquanto vazia, o QueueGate não renderiza e todos passam direto.
NEXT_PUBLIC_RIO_QUEUE_API_URL=https://rio-queue.dados.rio

# OpenTelemetry Configuration
# Enable/disable OpenTelemetry tracing
OTEL_ENABLED=false

# OpenTelemetry collector endpoint (gRPC)
# For Signoz: typically http://signoz-otel-collector:4317
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# Service identification
OTEL_SERVICE_NAME=citizen-portal
OTEL_SERVICE_VERSION=0.1.0

# Deployment environment (development, staging, production)
OTEL_ENVIRONMENT=development

# Trace sampling configuration
# OTEL_TRACES_SAMPLER options:
#   - always_on: Sample all traces (recommended for dev/staging)
#   - traceidratio: Sample a percentage of traces (recommended for production)
# Default: always_on
OTEL_TRACES_SAMPLER=always_on

# Sampling ratio when using traceidratio sampler (0.0 to 1.0)
# Examples:
#   - 1.0 = 100% (sample all traces)
#   - 0.1 = 10% (sample 10% of traces - good for high-traffic production)
#   - 0.01 = 1% (sample 1% of traces - for very high traffic)
# Default: 1.0
OTEL_TRACES_SAMPLER_ARG=1.0
